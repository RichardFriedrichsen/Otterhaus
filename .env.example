SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5173

# Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-step verification). Leave EMAIL_HOST_USER empty to print
# emails to the console instead of sending them.
EMAIL_HOST_USER=your.address@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your.address@gmail.com
